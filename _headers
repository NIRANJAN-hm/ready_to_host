/*
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; img-src 'self' data: https:; font-src 'self' data: https://fonts.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; script-src 'self' 'unsafe-inline'; connect-src 'self' https://formsubmit.co; form-action 'self' https://formsubmit.co; frame-src 'self' https://www.google.com https://www.youtube.com https://youtube.com https://www.youtube-nocookie.com; manifest-src 'self'; media-src 'self' https:; upgrade-insecure-requests
  Strict-Transport-Security: max-age=31536000
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  Cross-Origin-Resource-Policy: same-origin
  X-Permitted-Cross-Domain-Policies: none
  X-XSS-Protection: 0

/*.php
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/assets/*
  Cache-Control: public, max-age=604800

/images/*
  Cache-Control: public, max-age=604800

/PRE DESIGN/*
  Cache-Control: public, max-age=604800

/RENOVATION/*
  Cache-Control: public, max-age=604800

/RESDENTIAL DESIGN/*
  Cache-Control: public, max-age=604800
